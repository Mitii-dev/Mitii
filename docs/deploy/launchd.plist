  <dict>
    <key>Label</key>
    <string>dev.mitii.serve</string>
    <key>ProgramArguments</key>
    <array>
      <string>/usr/bin/env</string>
      <string>mitii</string>
      <string>serve</string>
      <string>--hostname</string>
