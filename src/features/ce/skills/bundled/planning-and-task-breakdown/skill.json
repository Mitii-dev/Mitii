{
  "schemaVersion": 1,
  "id": "planning-and-task-breakdown",
  "name": "Planning and task breakdown",
  "description": "Supporting planning skill that turns an active planning goal and existing evidence into a small, ordered, verifiable task list. Use only once planning is active and work needs decomposition; not a primary workflow like bugfix-workflow.",
  "version": "1.1.0",
  "apiVersion": "1",
  "owner": "mitii",
  "edition": "ce",
  "enabled": true,
  "status": "recommended",
  "kind": "workflow",
  "supportedModes": ["plan", "agent"],
  "intents": ["bugfix", "feature", "refactor"],
  "taskKinds": ["explicit_plan", "implementation"],
  "triggers": [
    "create an implementation plan",
    "break down the work",
    "task breakdown",
    "multi-step plan",
    "coordinate dependent changes",
    "plan this migration",
    "plan the implementation",
    "plan the repository repair",
    "break this into executable tasks"
  ],
  "negativeTriggers": [
    "what is",
    "explain",
    "commit message",
    "analyze this log",
    "fix this one-line typo",
    "single file change",
    "directly fix",
    "without planning",
    "without creating a plan",
    "skip planning",
    "no plan"
  ],
  "requiredTools": [],
  "optionalTools": ["read_file", "search", "repo_map"],
  "requiredCapabilities": ["repository-read"],
  "dependencies": [],
  "conflicts": [],
  "entrypoint": "SKILL.md",
  "referenceFiles": [],
  "maxInjectionChars": 4500,
  "injectionStrategy": "lazy-references",
  "trust": "builtin",
  "priority": 12,
  "tags": [
    "planning",
    "task-breakdown",
    "decomposition",
    "supporting-workflow",
    "plan-mode",
    "agent-planning"
  ],
  "pinningRules": [],
  "tests": [
    {
      "id": "positive-explicit-plan",
      "name": "Selects for an explicit implementation plan",
      "request": "Create an implementation plan for a multi-step feature with dependent changes",
      "mode": "plan",
      "availableTools": ["read_file", "search", "repo_map"],
      "availableCapabilities": ["repository-read"],
      "expected": "selected",
      "maxInjectionChars": 4500
    },
    {
      "id": "positive-task-breakdown",
      "name": "Selects when work must be broken into ordered tasks",
      "request": "Break this large implementation into small ordered tasks with acceptance criteria",
      "mode": "plan",
      "availableTools": ["read_file", "search", "repo_map"],
      "availableCapabilities": ["repository-read"],
      "expected": "selected",
      "maxInjectionChars": 4500
    },
    {
      "id": "positive-agent-planning",
      "name": "Selects as planning support for multi-step Agent work",
      "request": "Implement this multi-component change, but create a bounded plan before editing",
      "mode": "agent",
      "availableTools": ["read_file", "search", "repo_map"],
      "availableCapabilities": ["repository-read"],
      "expected": "selected",
      "maxInjectionChars": 4500
    },
    {
      "id": "positive-dependent-work",
      "name": "Selects for coordinated dependent changes",
      "request": "Plan the changes in dependency order because several components depend on each other",
      "mode": "plan",
      "availableTools": ["read_file", "search", "repo_map"],
      "availableCapabilities": ["repository-read"],
      "expected": "selected",
      "maxInjectionChars": 4500
    },
    {
      "id": "negative-simple-edit",
      "name": "Not selected for a localized edit",
      "request": "Fix this one-line typo",
      "mode": "agent",
      "availableTools": ["read_file", "search"],
      "availableCapabilities": ["repository-read"],
      "expected": "rejected"
    },
    {
      "id": "negative-question",
      "name": "Not selected for a general question",
      "request": "What is dependency injection?",
      "mode": "ask",
      "availableTools": ["read_file", "search"],
      "availableCapabilities": ["repository-read"],
      "expected": "rejected"
    },
    {
      "id": "negative-commit-message",
      "name": "Not selected for commit-message generation",
      "request": "Write a commit message for my staged changes",
      "mode": "ask",
      "availableTools": ["read_file", "search"],
      "availableCapabilities": ["repository-read"],
      "expected": "rejected"
    },
    {
      "id": "negative-log-analysis",
      "name": "Not selected for log analysis",
      "request": "Analyze this agent log and identify the failures",
      "mode": "ask",
      "availableTools": ["read_file", "search"],
      "availableCapabilities": ["repository-read"],
      "expected": "rejected"
    },
    {
      "id": "negative-direct-override",
      "name": "Not selected when planning is disabled",
      "request": "Make the change directly without creating a plan",
      "mode": "agent",
      "availableTools": ["read_file", "search"],
      "availableCapabilities": ["repository-read"],
      "expected": "rejected"
    }
  ]
}
